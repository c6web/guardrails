{
  "description": "OpenAI client → Ollama upstream: chat with images and tools",
  "client_dialect": "openai",
  "upstream_vendor": "ollama",
  "feature": "images_and_tools",
  "note": "Gateway translates OpenAI format to Ollama native /api/chat endpoint",
  "request": {
    "method": "POST",
    "path": "/v1/chat/completions",
    "headers": {
      "content-type": "application/json",
      "authorization": "Bearer sk-test-key"
    },
    "body": {
      "model": "llama3.2",
      "messages": [
        {"role": "user", "content": "What's in this image?", "images": ["base64data123"]}
      ],
      "tools": [
        {
          "type": "function",
          "function": {
            "name": "analyze_image",
            "description": "Analyze an image and describe it",
            "parameters": {"type": "object"}
          }
        }
      ]
    }
  },
  "expected_upstream_request": {
    "method": "POST",
    "path": "/api/chat",
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "model": "llama3.2",
      "messages": [
        {"role": "user", "content": "What's in this image?", "images": ["base64data123"]}
      ],
      "stream": false,
      "options": {
        "num_predict": 500
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "model": "llama3.2",
      "message": "The image shows a sunset over the ocean.",
      "done": true
    }
  },
  "expected_downstream_response": {
    "status": 200,
    "headers": {
      "content-type": "application/json"
    },
    "body": {
      "id": "chatcmpl-ollama-001",
      "object": "chat.completion",
      "model": "llama3.2",
      "choices": [
        {
          "index": 0,
          "message": {
            "role": "assistant",
            "content": "The image shows a sunset over the ocean."
          },
          "finish_reason": "stop"
        }
      ],
      "usage": {
        "prompt_tokens": 25,
        "completion_tokens": 10,
        "total_tokens": 35
      }
    }
  }
}
