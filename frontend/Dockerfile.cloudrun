FROM node:24-alpine AS build
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm install
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html

# Replace main nginx.conf entirely (no conf.d/* includes)
COPY nginx-cloudrun.conf /etc/nginx/nginx.conf

# Remove default templates that might regenerate configs
RUN rm -rf /etc/nginx/conf.d/ /etc/nginx/templates/

EXPOSE 8080
