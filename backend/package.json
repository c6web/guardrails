{
  "name": "c6-guardrails-backend",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "lint": "eslint src/ --ext .ts,.js",
    "start": "node dist/app.js",
    "migrate": "npm run migrate:users && npm run migrate:data && npm run migrate:logs",
    "migrate:users": "sequelize-cli db:migrate --config src/config/sequelize-users.cts --migrations-path src/migrations/users-db",
    "migrate:data": "sequelize-cli db:migrate --config src/config/sequelize-data.cts  --migrations-path src/migrations/data-db",
    "migrate:logs": "sequelize-cli db:migrate --config src/config/sequelize-logs.cts  --migrations-path src/migrations/logs-db",
    "migrate:undo": "npm run migrate:undo:users && npm run migrate:undo:data && npm run migrate:undo:logs",
    "migrate:undo:users": "sequelize-cli db:migrate:undo:all --config src/config/sequelize-users.cts --migrations-path src/migrations/users-db",
    "migrate:undo:data": "sequelize-cli db:migrate:undo:all --config src/config/sequelize-data.cts  --migrations-path src/migrations/data-db",
    "migrate:undo:logs": "sequelize-cli db:migrate:undo:all --config src/config/sequelize-logs.cts  --migrations-path src/migrations/logs-db",
    "seed": "npm run seed:data && npm run seed:users && npm run seed:logs",
    "seed:data": "sequelize-cli db:seed:all --config src/config/sequelize-data.cts  --seeders-path src/seeders/data-db",
    "seed:users": "sequelize-cli db:seed:all --config src/config/sequelize-users.cts --seeders-path src/seeders/users-db",
    "seed:logs": "sequelize-cli db:seed:all --config src/config/sequelize-logs.cts  --seeders-path src/seeders/logs-db",
    "seed:undo": "npm run seed:undo:data && npm run seed:undo:users && npm run seed:undo:logs",
    "seed:undo:data": "sequelize-cli db:seed:undo:all --config src/config/sequelize-data.cts  --seeders-path src/seeders/data-db",
    "seed:undo:users": "sequelize-cli db:seed:undo:all --config src/config/sequelize-users.cts --seeders-path src/seeders/users-db",
    "seed:undo:logs": "sequelize-cli db:seed:undo:all --config src/config/sequelize-logs.cts  --seeders-path src/seeders/logs-db"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.7",
    "pg": "^8.12.0",
    "pgvector": "^0.2.1",
    "sequelize": "^6.37.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0"
  }
}
