# PostgreSQL (docker-compose services)
POSTGRES_DB=ai_gateway_data
POSTGRES_PASSWORD=gafplatform6833
DB_USER=c6admin
DB_PASSWORD=gafplatform6833

# Backend DB connections
DB_HOST=localhost
DB_PORT=5432
DB_USER=c6admin
DB_PASSWORD=gafplatform6833
DB_USERS=ai_gateway_users
DB_DATA=ai_gateway_data
DB_LOGS=ai_gateway_logs

# Log store driver: postgresql (default)
LOG_STORE_DRIVER=postgresql
LOG_PG_HOST=localhost
LOG_PG_PORT=5432
LOG_PG_USER=c6admin
LOG_PG_PASSWORD=gafplatform6833
LOG_PG_DB=ai_gateway_logs

# JWT + encryption secrets (all required — generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
# Single AES-256-GCM secret for all encryption-at-rest: gateway control keys, app API keys,
# AI/embedding provider API keys, admin keys, notification server credentials, sensitive log fields
PLATFORM_KEY_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
# Reject boot if JWT_SECRET or PLATFORM_KEY_SECRET is < 32 chars (default: false)
REQUIRE_STRONG_SECRETS=false

# SMTP (email OTP / notifications — optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# Admin seed credentials (set all 3 to auto-create admin on first startup)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@c6web.local
ADMIN_PASSWORD=gafpass

# CORS origins (comma-separated, e.g. "http://localhost:3634,http://192.168.3.97:3634")
CORS_ORIGIN=http://localhost:3634,http://192.168.3.97:3634

# Trusted proxy (security — set when behind nginx / reverse proxy)
TRUSTED_PROXY_DEPTH=0
TRUSTED_PROXY_IPS=

# Backend server
PORT=3635
NODE_ENV=development
# Grace period (seconds) for API key rotation; default 86400 (24h)
GATEWAY_API_KEY_GRACE_PERIOD=86400

# GatewayEngine (Rust proxy)
DATA_PG_HOST=localhost
DATA_PG_PORT=5432
DATA_PG_USER=c6admin
DATA_PG_PASSWORD=gafplatform6833
DATA_PG_DB=ai_gateway_data
RATE_LIMIT_RPM=120
GATEWAY_INSTANCE_ID=00000002-0000-0000-0000-000000000001
# Pre-auth per-IP rate limit (requests/min)
PREAUTH_RATE_LIMIT_RPM=300
# Fail-closed: true = block on embedding/classifier errors; default false (fail-open)
SCAN_FAIL_CLOSED=false
# Allow private IPs for upstream providers (dev only — not for production)
SSRF_PRIVATE_ALLOWED=false
# Max request body size (in MB)
GATEWAY_BODY_LIMIT_MB=8

# Response cache — master kill switch (deploy-time). Must be true for caching to work
# at all, regardless of the console's global toggle or any per-app checkbox — all three
# gates are required. See semantic_caching.md.
RESPONSE_CACHE_ENABLED=false
RESPONSE_CACHE_MAX_TTL_SECONDS=900
RESPONSE_CACHE_DEFAULT_TTL_SECONDS=300
RESPONSE_CACHE_CLEANUP_INTERVAL_SECONDS=120
RESPONSE_CACHE_LOOKUP_TIMEOUT_MS=50

# Frontend (Vite)
VITE_BACKEND_URL=http://localhost:3635
VITE_BUILD_TYPE=development

# Telemetry / observability (opt-in)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=gateway-engine
RUST_LOG=info
